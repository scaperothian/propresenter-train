          "alpha": 1.0
        },
        "slides": [
          {
            "enabled": true,
            "notes": "",
            "text": "But I'm just a soul \nwhose intentions are good\nOh Lord, please don't let me be misunderstood",
            "label": "",
            "size": {
              "width": 1920,
              "height": 1080
            },
            "trigger time": [
