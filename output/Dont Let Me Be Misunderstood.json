          "alpha": 1.0
        },
        "slides": [
          {
            "enabled": true,
            "notes": "",
            "text": "If I seem edgy, I want you to know, \nThat I never mean to take it out on you",
            "label": "",
            "size": {
              "width": 1920,
              "height": 1080
            },
            "trigger time": [
              78.996
            ]
          },
          {
            "enabled": true,
            "notes": "",
            "text": "Life has its problems, and I get my share, \nAnd that's one thing I'd never mean to do\n'Cause I love you",
            "label": "",
            "size": {
              "width": 1920,
              "height": 1080
            },
            "trigger time": [
