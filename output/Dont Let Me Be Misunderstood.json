          "alpha": 1.0
        },
        "slides": [
          {
            "enabled": true,
            "notes": "",
            "text": "Baby, sometimes I'm so carefree, \nWith a joy that's hard to hide",
            "label": "",
            "size": {
              "width": 1920,
              "height": 1080
            },
            "trigger time": [
              50.874
            ]
          },
          {
            "enabled": true,
            "notes": "",
            "text": "And sometimes, \nit seems that all I have do is worry\nAnd then you're bound \nto see my other side",
            "label": "",
            "size": {
              "width": 1920,
              "height": 1080
            },
            "trigger time": [
